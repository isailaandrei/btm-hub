# BTM Hub — environment variables (names only; fill in per deployment).
# Mirrors the "Env vars to port" list in
# docs/plans/vercel-to-hostinger-migration.md. NEXT_PUBLIC_* values are baked in
# at BUILD time (changing one requires a rebuild/redeploy); everything else is
# read at runtime. Never commit real values.

# --- Public (NEXT_PUBLIC_*, baked into the client bundle at build) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_STREAM_CHAT_API_KEY=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SHOW_ADMIN_AI=

# --- Supabase (server) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Sanity (server) ---
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=

# --- Stream Chat (server) ---
STREAM_CHAT_API_SECRET=
STREAM_CHAT_TOKEN_TTL_SECONDS=

# --- Brevo (email provider) ---
BREVO_API_KEY=
BREVO_FROM_EMAIL=
BREVO_WEBHOOK_TOKEN=

# --- Email pipeline ---
EMAIL_PROVIDER=
EMAIL_FROM_EMAIL=
EMAIL_FROM_NAME=
EMAIL_REPLY_TO_EMAIL=
EMAIL_WORKER_SECRET=
EMAIL_WORKER_ORIGIN=
EMAIL_REQUIRE_REAL_PROVIDER=
# Pilot only — redirects every provider recipient to this address. Forbidden in production.
EMAIL_TEST_RECIPIENT_OVERRIDE=

# --- Deployment environment ---
# Set APP_ENV=production ONLY on the real production deployment; leave it unset on
# the Hostinger pilot (see the email-environment model in the migration plan).
APP_ENV=

# --- Admin notifications / owner forwarding ---
ADMIN_NOTIFICATION_EMAIL=
OWNER_EMAIL_FORWARD_TO=

# --- OpenAI / admin AI ---
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_CONVERSATION_DIGEST_MODEL=
OPENAI_GLOBAL_PROMPT_CACHE_RETENTION=
ADMIN_AI_INCLUDE_EVIDENCE=
# Active admin-AI synthesis provider: "openai" (default when unset) or "deepseek".
ADMIN_AI_PROVIDER=
# Global-scan strategy: "single" (default) one-pass, or "map_reduce" chunked
# recall + synthesis (requires ADMIN_AI_PROVIDER=deepseek).
ADMIN_AI_SCAN_MODE=

# --- DeepSeek (admin AI, OpenAI-compatible chat-completions) ---
# Required when ADMIN_AI_PROVIDER=deepseek; enables the provider.
DEEPSEEK_API_KEY=
# Model id (default deepseek-v4-flash; deepseek-v4-pro also available).
DEEPSEEK_MODEL=
# API base URL (default https://api.deepseek.com); override for US/EU hosts.
DEEPSEEK_BASE_URL=
# Enable DeepSeek reasoning ("thinking") mode for admin-AI synthesis (default off).
DEEPSEEK_THINKING=
# Reasoning depth when thinking is on: "high" (default) or "max"; other values error.
DEEPSEEK_REASONING_EFFORT=

# --- WhatsApp (YCloud) ---
YCLOUD_API_KEY=
YCLOUD_WEBHOOK_SECRET=

# --- Cron / inbound webhooks ---
CRON_SECRET=
COMMUNITY_WEBHOOK_SECRET=

# --- Misc ---
DEFAULT_PHONE_REGION=

# --- Optional debug (leave unset in production) ---
DEBUG_ADMIN_AI=
ADMIN_AI_PRINT_OPENAI_PAYLOAD=

# --- Intentionally NOT listed ---
# VERCEL_ENV / VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL — injected by Vercel;
#   replaced on Hostinger by APP_ENV + NEXT_PUBLIC_SITE_URL + EMAIL_WORKER_ORIGIN.
# NODE_ENV — set by `next build` / `next start`, never by hand.
# RESEND_API_KEY / EMAIL_FROM — dead code (removed).
# Local tooling only, not a deployment var: SUPABASE_DB_URL,
#   SUPABASE_LOCAL_SERVICE_ROLE_KEY, PSQL_BIN (used by supabase/scripts + local dev).
