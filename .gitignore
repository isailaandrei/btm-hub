#Scripts (top-level user scratchpad only; supabase/scripts/ stays tracked)
/scripts/*
!/scripts/admin-ai-memory/
!/scripts/admin-ai-memory/**

#wiki
/wiki
.wiki-compiler.json

# superpowers brainstorming
.superpowers/
/docs/superpowers/plans
/docs/superpowers/specs

# Data imports — CSV files with applicant PII
*.csv
backup_schema_*.sql
supabase/import-*.sql
# Locally-generated seed slices that contain PII (e.g., applications
# imported from partner A's Google Forms CSVs via
# supabase/scripts/import-academy-applications.mjs)
supabase/seed.*.local.sql
# Local scratchpad — production memory snapshots, ad-hoc query JSON, etc.
# May contain identifiable applicant data; never commit.
/tmp/
# Local Supabase Studio scratchpad (saved SQL snippets)
supabase/snippets/